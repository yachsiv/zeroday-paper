{
  "app": "python3 infra/app.py",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "*.pyc",
      "**/__pycache__",
      "tests",
      "data",
      "reports",
      "logs"
    ]
  },
  "context": {
    "@aws-cdk/core:newStyleStackSynthesis": true,
    "@aws-cdk/aws-iam:minimizePolicies": true,
    "@aws-cdk/core:enablePartitionLiterals": true,
    "@aws-cdk/aws-ecr-assets:dockerIgnoreSupport": true
  }
}
