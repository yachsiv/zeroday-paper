# Local-dev overrides. In AWS, all of these are pulled from Secrets Manager.
# Copy to `.env` and fill in for `uv run` local execution.

# AWS region (Secrets Manager + CloudWatch + EFS)
AWS_REGION=us-east-1

# Pulled from AWS Secrets Manager in production. Override for local dev only.
POLYGON_API_KEY=
FLASHALPHA_API_KEY=
ANTHROPIC_API_KEY=
DISCORD_WEBHOOK_URL=

# Local storage
ZP_DUCKDB_PATH=./data/paper.duckdb
ZP_REPORT_DIR=./reports
ZP_LOG_DIR=./logs

# Optional: pin Anthropic model
ZP_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
